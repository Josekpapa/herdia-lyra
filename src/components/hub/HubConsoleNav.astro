---
/** Persistent sub-navigation for the Hub operator console (ecosystem inside LYRA). */
interface Props {
  current: "overview" | "ecosystem" | "drafts" | "services" | "batches";
}

const { current } = Astro.props;

const tabs: { href: string; key: Props["current"]; label: string }[] = [
  { href: "/hub", key: "overview", label: "Overview" },
  { href: "/hub/ecosystem", key: "ecosystem", label: "Ecosystem map" },
  { href: "/hub/drafts", key: "drafts", label: "SKU pipeline" },
  { href: "/hub/services", key: "services", label: "Service catalog" },
  { href: "/hub/batches", key: "batches", label: "Interface batches" },
];
---

<nav
  class="mt-6 flex flex-wrap gap-2 border-b border-white/5 pb-4"
  aria-label="Hub console sections"
>
  {
    tabs.map((t) => (
      <a
        href={t.href}
        class:list={[
          "rounded-md px-3 py-2 font-mono text-[11px] tracking-wide transition",
          current === t.key
            ? "bg-white/[0.08] text-white ring-1 ring-white/15"
            : "bg-white/[0.02] text-ink-400 hover:bg-white/[0.05] hover:text-ink-200",
        ]}
      >
        {t.label}
      </a>
    ))
  }
</nav>
