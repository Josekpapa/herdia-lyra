---
/**
 * Shared Matter-pattern layout for generated sub-agent landings.
 */
import AtlasLayout from "../../layouts/AtlasLayout.astro";
import AgentTile from "./AgentTile.astro";
import type { Holding, Agent } from "../../data/atlas";
import { getInterfacePreviewForProduct } from "../../data/interfaceBatches";
import type { SubAgentCopy } from "../../data/subAgentCopy/types";
import { flagshipPath, flagshipName } from "../../data/subAgentCopy/types";
import type { LyraLocale } from "../../i18n/shell";
import SubAgentInterfacePanel from "./SubAgentInterfacePanel.astro";

interface Props {
  holding: Holding;
  agent: Agent;
  copy: SubAgentCopy;
  locale?: LyraLocale;
}

const { holding, agent, copy, locale = "en" } = Astro.props;
const accent = holding.voice.palette[0] ?? "#ffffff";
const interfacePreview = getInterfacePreviewForProduct(holding.slug, agent.slug);
const isDraft = agent.status === "draft";
const related = holding.agents
  .filter((a) => a.slug !== agent.slug)
  .sort((a, b) => {
    if (a.status === b.status) return 0;
    return a.status === "live" ? -1 : 1;
  })
  .slice(0, 5);
const kickerId = `${holding.code}.${agent.slug}`;
const fp = flagshipPath(holding);
const fn = flagshipName(holding);
---

<AtlasLayout
  title={`${agent.name} — ${holding.name} · LYRA`}
  description={agent.blurb}
  active={holding.slug}
>
  <section class="lyra-sec overflow-hidden border-b border-white/5">
    <div
      class="lyra-layer-bg"
      style={`background: radial-gradient(1100px 600px at 18% 20%, color-mix(in oklab, ${accent} 14%, transparent), transparent 58%), radial-gradient(760px 480px at 82% 72%, rgba(74, 110, 184, 0.07), transparent 62%);`}
    ></div>
    <div class="lyra-layer-content mx-auto max-w-[84rem] px-6 py-24 sm:py-32">
      <div class="flex items-center gap-2 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-500">
        <a href="/atlas" class="hover:text-white transition" data-shell-i18n="atlas.nav.atlas">Atlas</a>
        <span>/</span>
        <a href={`/${holding.slug}`} class="hover:text-white transition">{holding.name}</a>
        <span>/</span>
        <span class="text-ink-300">{agent.name}</span>
      </div>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <span class="kicker"><span data-shell-i18n="product.kicker.agent">Agent ·</span> {kickerId}</span>
        {
          isDraft ? (
            <span class="tag border-amber-500/35 bg-amber-500/10 text-amber-200/90" data-shell-i18n="product.status.roadmap">
              ○ roadmap
            </span>
          ) : (
            <span class="tag tag-accent" data-shell-i18n="product.status.live">
              ● live
            </span>
          )
        }
        <span class="label-xs">{agent.tier}</span>
      </div>
      {
        isDraft && (
          <div class="mt-6 max-w-3xl rounded-lg border border-amber-500/25 bg-amber-500/[0.06] px-5 py-4">
            <div class="font-mono text-[10px] tracking-[0.2em] text-amber-200/90" data-shell-i18n="product.roadmap.kicker">
              ROADMAP AGENT
            </div>
            <p class="mt-2 text-sm leading-relaxed text-ink-200" data-shell-i18n="product.roadmap.banner">
              Narrative and tier grammar ship now; Passport wiring, operator shell, and GA SKU follow the interface-dev sequence and service catalog. Request access to co-shape the first runbooks.
            </p>
            <div class="mt-4 flex flex-wrap gap-3 font-mono text-[11px]">
              <a href="/hub/batches" class="text-amber-200/90 underline decoration-amber-500/30 hover:decoration-amber-400/50">
                Interface batches →
              </a>
              <a href="/hub/drafts" class="text-ink-400 underline decoration-white/15 hover:text-ink-200 hover:decoration-white/35">
                All roadmap agents →
              </a>
            </div>
          </div>
        )
      }
      <h1 class="mt-8 font-display text-[clamp(3rem,10vw,8rem)] font-light leading-[0.9] tracking-tight text-white">
        {agent.name}
      </h1>
      <p class="mt-4 max-w-2xl font-display text-2xl italic font-light text-ink-200/90">
        {copy.heroItalic}
      </p>
      <div class="hairline mt-8 max-w-md"></div>
      <p class="mt-8 max-w-3xl text-lg leading-relaxed text-ink-200 lede">
        {copy.heroLede}
      </p>
      <div class="mt-12 flex flex-wrap items-center gap-3">
        <a href="/join" class="btn-primary" data-shell-i18n="product.cta.requestAccessArrow">Request access →</a>
        <a href="#how" class="btn-ghost" data-shell-i18n="product.link.how">How it works</a>
        <a href="#pricing" class="btn-link" data-shell-i18n="product.link.pricingNav">Pricing ↓</a>
      </div>
      <div class="mt-16 grid grid-cols-2 gap-6 border-t border-white/5 pt-8 sm:grid-cols-4">
        {copy.stats.map((s) => (
          <div>
            <div class="label-xs">{s.label}</div>
            <div class="mt-1 font-light leading-snug text-white data-num text-2xl sm:text-3xl">{s.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-5 md:items-start">
        <div class="md:col-span-2">
          <div class="kicker mb-3">{copy.whyTitle}</div>
          <h2 class="section-title">{copy.whyH2}</h2>
        </div>
        <div class="md:col-span-3">
          <p class="text-base leading-relaxed text-ink-200">{copy.whyP1}</p>
          <p class="mt-6 text-base leading-relaxed text-ink-300">{copy.whyP2}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">{copy.replaceKicker}</div>
      <h2 class="page-title">{copy.replaceH2}</h2>
      <p class="mt-4 max-w-2xl text-sm text-ink-400">{copy.replaceSub}</p>
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="surface-warm p-8">
          <div class="label-xs text-ink-500" data-shell-i18n="product.replace.before">Before</div>
          <ul class="mt-6 space-y-3 text-sm leading-relaxed text-ink-300">
            {copy.before.map((line) => (
              <li class="flex gap-3">
                <span class="font-mono text-ink-500">—</span>
                {line}
              </li>
            ))}
          </ul>
        </div>
        <div
          class="surface p-8"
          style={`border-color: color-mix(in oklab, ${accent} 28%, rgba(255,255,255,0.06));`}
        >
          <div class="label-xs" style={`color: ${accent};`}><span data-shell-i18n="product.replace.afterPrefix">After ·</span> {agent.name}</div>
          <ul class="mt-6 space-y-3 text-sm leading-relaxed text-ink-200">
            {copy.after.map((line) => (
              <li class="flex gap-3">
                <span class="font-mono" style={`color:${accent};`}>●</span>
                {line}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  {interfacePreview && (
    <SubAgentInterfacePanel holding={holding} agent={agent} preview={interfacePreview} accent={accent} copy={copy} locale={locale} />
  )}

  <section id="how" class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3" data-shell-i18n="product.kicker.how">How it works</div>
      <h2 class="page-title">{copy.howH2}</h2>
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        {copy.steps.map((step) => (
          <div class="surface p-6">
            <div class="label-xs text-white">{step.label}</div>
            <p class="mt-3 text-[14px] leading-relaxed text-ink-200">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-white/5" data-page="app">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-5 lg:items-start">
        <div class="lg:col-span-2">
          <div class="kicker mb-3" data-shell-i18n="product.kicker.terminal">Terminal</div>
          <h2 class="section-title">{copy.terminalTitle}</h2>
          <p class="mt-4 text-sm text-ink-400">{copy.terminalSub}</p>
        </div>
        <div class="lg:col-span-3">
          <div
            class="surface corner-ticks p-8"
            style={`border-color: color-mix(in oklab, ${accent} 26%, rgba(255,255,255,0.06));`}
          >
            <div class="flex items-center justify-between">
              <span class="label-xs text-white">
                {holding.name.toUpperCase()} · {agent.name.toUpperCase()} ·{" "}
                {isDraft ? (
                  <span data-shell-i18n="product.terminal.roadmap">ROADMAP</span>
                ) : (
                  <span data-shell-i18n="product.terminal.live">LIVE</span>
                )}
              </span>
              {
                isDraft ? (
                  <span class="tag border-amber-500/35 bg-amber-500/10 text-amber-200/90" data-shell-i18n="product.status.roadmap">
                    ○ roadmap
                  </span>
                ) : (
                  <span class="tag tag-accent" data-shell-i18n="product.status.live">
                    ● live
                  </span>
                )
              }
            </div>
            <pre class="mt-6 whitespace-pre-wrap font-mono text-[12.5px] leading-relaxed text-ink-200">{copy.terminalBody}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-5 md:items-start">
        <div class="md:col-span-2">
          <div class="kicker mb-3" data-shell-i18n="product.kicker.usecase">Use case</div>
          <h2 class="section-title">{copy.useH2}</h2>
          <p class="mt-4 text-sm text-ink-400">{copy.useSub}</p>
        </div>
        <div class="md:col-span-3 space-y-6">
          {copy.useBlocks.map((b, i) => (
            <div
              class="surface p-6"
              style={
                i === copy.useBlocks.length - 1
                  ? `border-color: color-mix(in oklab, ${accent} 26%, rgba(255,255,255,0.06));`
                  : undefined
              }
            >
              <div class="label-xs text-white">{b.label}</div>
              <p class="mt-3 text-[14px] leading-relaxed text-ink-200">{b.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="pricing" class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3"><span data-shell-i18n="product.kicker.pricingPrefix">Pricing ·</span> {agent.name}</div>
      <h2 class="page-title">{copy.pricingH2}</h2>
      <p class="mt-4 max-w-xl text-sm text-ink-400">{copy.pricingSub}</p>
      <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-3">
        {copy.tiers.map((t) => (
          <div
            class:list={["surface p-8", t.recommended && "md:-translate-y-2"]}
            style={t.recommended ? `border-color: color-mix(in oklab, ${accent} 34%, rgba(255,255,255,0.06));` : undefined}
          >
            <div class="flex items-start justify-between">
              <div class="label-xs">{t.name}</div>
              {t.recommended && <span class="tag tag-accent" data-shell-i18n="product.pricing.recommended">Recommended</span>}
            </div>
            <div class="mt-6 font-display text-4xl font-light text-white data-num">{t.price}</div>
            <p class="mt-3 text-[13px] leading-relaxed text-ink-300">{t.note}</p>
            <a href="/join" class:list={[t.recommended ? "btn-primary" : "btn-ghost", "mt-8 inline-block"]} data-shell-i18n="product.cta.requestAccess">
              Request access
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-16">
      <div class="kicker mb-3" data-shell-i18n="product.kicker.integrations">Integrations</div>
      <h2 class="section-title">{copy.intH2}</h2>
      <p class="mt-3 text-sm text-ink-400">{copy.intSub}</p>
      <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        {copy.integrations.map((n) => (
          <div class="surface px-4 py-3 text-center">
            <div class="font-mono text-[11px] tracking-wider text-ink-300">{n}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-16">
      <div class="kicker mb-3"><span data-shell-i18n="product.kicker.moreInside">More inside</span> {holding.name}</div>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-5">
        {related.map((a) => (
          <AgentTile agent={a} holdingSlug={holding.slug} />
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-[84rem] px-6 py-24">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div>
          <div class="kicker mb-3" data-shell-i18n="product.kicker.designPartner">Design partner cohort</div>
          <h2 class="page-title">{copy.ctaH2}</h2>
          <p class="mt-4 max-w-xl text-sm text-ink-300">{copy.ctaBody}</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/join" class="btn-primary" data-shell-i18n="product.cta.apply">Apply →</a>
          <a href={fp} class="btn-ghost"><span data-shell-i18n="product.seeFlagshipPrefix">See</span> {fn}</a>
          <a href={`/${holding.slug}`} class="btn-link"><span data-shell-i18n="product.cta.backPrefix">Back to</span> {holding.name} <span data-shell-i18n="product.cta.backArrow">→</span></a>
        </div>
      </div>
      <p class="mt-8 font-mono text-[10px] text-ink-500">{copy.designPartnerLine}</p>
    </div>
  </section>
</AtlasLayout>
