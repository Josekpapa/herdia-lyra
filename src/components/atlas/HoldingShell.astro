---
/**
 * HoldingShell — shared body template for every holding landing page.
 *
 * Every holding page (/tide, /lore, /helios, ...) renders this with its Holding
 * object from src/data/atlas.ts. The shell covers: terminal hero · flagship ·
 * agents grid · pricing · sell · rituals · in-network bridges. Each page can
 * still prepend/append cinematic sections; this is the backbone.
 */
import type { Holding } from "../../data/atlas";
import AgentTile from "./AgentTile.astro";

interface Props {
  holding: Holding;
}

const { holding: h } = Astro.props;
const liveCount = h.agents.filter((a) => a.status === "live").length;
const draftCount = h.agents.filter((a) => a.status === "draft").length;

// Brand color strip used in hero — first palette slot.
const accent = h.voice.palette[0];
---

<!-- ───────────────── TERMINAL HERO ───────────────── -->
<section class="relative border-b border-white/5">
  <div class="mx-auto max-w-[84rem] px-6 py-20 sm:py-28">
    <div class="flex items-center gap-3">
      <span class="kicker">Holding · {h.code}</span>
      <span class="label-xs">{h.vertical}</span>
    </div>

    <h1 class="mt-6 font-display text-[clamp(3rem,7vw,6rem)] font-light leading-[0.95] tracking-tight text-white">
      {h.name}
    </h1>

    <p class="mt-4 max-w-2xl font-display text-xl italic font-light text-ink-200/90">
      {h.tagline}
    </p>

    <div class="hairline mt-8 max-w-md"></div>

    <p class="mt-8 max-w-3xl text-lg leading-relaxed text-ink-200 lede">
      {h.thesis}
    </p>

    <!-- Brand strip — 3 palette swatches expose the holding's voice -->
    <div class="mt-10 flex items-center gap-4">
      {h.voice.palette.map((c) => (
        <span
          class="h-6 w-10 border border-white/10"
          style={`background:${c};`}
          aria-hidden="true"
        ></span>
      ))}
      <span class="label-xs">{h.voice.tone}</span>
    </div>

    <!-- Metrics row -->
    <div class="mt-12 grid grid-cols-2 gap-6 border-t border-white/5 pt-6 sm:grid-cols-4">
      <div>
        <div class="label-xs">Live agents</div>
        <div class="mt-1 data-num text-3xl font-light text-white">{liveCount}</div>
      </div>
      <div>
        <div class="label-xs">Drafting</div>
        <div class="mt-1 data-num text-3xl font-light text-ink-300">{draftCount}</div>
      </div>
      <div>
        <div class="label-xs">North-star</div>
        <div class="mt-1 text-sm text-ink-200">{h.persona}</div>
      </div>
      <div>
        <div class="label-xs">Year-1 floor</div>
        <div class="mt-1 text-sm text-ink-200">{h.firstRevenue}</div>
      </div>
    </div>

    <!-- CTA row -->
    <div class="mt-10 flex flex-wrap items-center gap-3">
      {h.flagship && (
        <a
          href={h.flagship.externalHtml ?? `/${h.slug}/${h.flagship.slug}`}
          class="btn-primary"
        >
          Open {h.flagship.name} →
        </a>
      )}
      <a href="/join" class="btn-ghost">Request access</a>
      <a href="/pricing" class="btn-link">See pricing →</a>
    </div>
  </div>
</section>

<!-- ───────────────── FLAGSHIP CARD ───────────────── -->
{h.flagship && (
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-16">
      <div class="kicker mb-4">Flagship</div>
      <div class="surface-warm p-8 sm:p-12">
        <div class="flex flex-col gap-8 sm:flex-row sm:items-end sm:justify-between">
          <div class="min-w-0 flex-1">
            <h2 class="font-display text-4xl font-light tracking-tight text-white">
              {h.flagship.name}
            </h2>
            <p class="mt-3 max-w-2xl text-base text-ink-200 leading-relaxed">
              {h.flagship.blurb}
            </p>
            <p class="mt-5 text-sm italic text-ink-400">
              Metaphor: <span class="text-ink-200">{h.voice.metaphor}</span>
            </p>
          </div>
          <div class="flex items-center gap-3">
            <a
              href={h.flagship.externalHtml ?? `/${h.slug}/${h.flagship.slug}`}
              class="btn-primary"
            >
              Enter {h.flagship.name}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<!-- ───────────────── AGENT CATALOG ───────────────── -->
<section class="border-b border-white/5">
  <div class="mx-auto max-w-[84rem] px-6 py-16">
    <div class="flex items-end justify-between">
      <div>
        <div class="kicker mb-2">Catalog · {liveCount} live · {draftCount} drafting</div>
        <h2 class="section-title">Agents under {h.name}</h2>
      </div>
      <a href="/atlas" class="btn-link">All agents →</a>
    </div>
    <div class="mt-10 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {h.agents.map((a) => (
        <AgentTile agent={a} holdingSlug={h.slug} />
      ))}
    </div>
  </div>
</section>

<!-- ───────────────── PRICING ───────────────── -->
<section class="border-b border-white/5">
  <div class="mx-auto max-w-[84rem] px-6 py-16">
    <div class="kicker mb-2">Pricing · {h.name}</div>
    <h2 class="section-title">How {h.name} is priced</h2>
    <p class="mt-3 max-w-2xl text-sm text-ink-400">{h.model}</p>

    <div class="mt-10 grid grid-cols-1 gap-3 md:grid-cols-3">
      {h.pricing.map((p) => (
        <div class="surface p-6">
          <div class="label-xs">{p.tier}</div>
          <div class="mt-2 font-display text-2xl font-light text-white">{p.price}</div>
          <p class="mt-2 text-sm text-ink-300">{p.for}</p>
        </div>
      ))}
    </div>

    <div class="mt-8 flex items-center gap-3">
      <a href="/pricing" class="btn-ghost">Full tier grammar</a>
      <a href="/join" class="btn-link">Request access →</a>
    </div>
  </div>
</section>

<!-- ───────────────── SELL · RITUALS ───────────────── -->
<section class="border-b border-white/5">
  <div class="mx-auto max-w-[84rem] px-6 py-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
      <div>
        <div class="kicker mb-2">Sell motion</div>
        <h2 class="section-title">Who this is for</h2>
        <p class="mt-4 text-base text-ink-200 leading-relaxed">{h.sell}</p>
        <p class="mt-6 text-sm text-ink-400">
          North-star persona: <span class="text-ink-200">{h.persona}</span>
        </p>
      </div>
      <div>
        <div class="kicker mb-2">Rituals</div>
        <h2 class="section-title">How {h.name} is operated</h2>
        <ul class="mt-6 space-y-3">
          {h.rituals.map((r) => (
            <li class="flex items-baseline gap-3 text-sm">
              <span class="font-mono text-ink-500">—</span>
              <span class="text-ink-200">{r}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ───────────────── IN-NETWORK BRIDGES ───────────────── -->
<section>
  <div class="mx-auto max-w-[84rem] px-6 py-16">
    <div class="kicker mb-2">In the network</div>
    <h2 class="section-title">{h.name} connects to every other holding</h2>
    <p class="mt-4 max-w-2xl text-sm text-ink-300">
      Every agent inside {h.name} reads the same identity, memory, and voice
      that every other LYRA holding uses. One login, one invoice, one network.
    </p>
    <div class="mt-8 flex flex-wrap gap-2">
      <a href="/atlas" class="tag hover:border-white/30 transition">Atlas catalog →</a>
      <a href="/passport" class="tag hover:border-white/30 transition">Passport →</a>
      <a href="/founders-day" class="tag hover:border-white/30 transition">Founder's Day →</a>
      <a href="/agency" class="tag hover:border-white/30 transition">Hire LYRA →</a>
    </div>
  </div>
</section>
