---
import { shellLabels, LYRA_LOCALE_STORAGE_KEY, LYRA_LOCALE_COOKIE } from "../../i18n/shell";

const locales = ["en", "es", "de"] as const;
---

<div class="lyra-lang-switcher" aria-label="Language">
  {
    locales.map((lang) => (
      <button
        type="button"
        class="lyra-lang-btn"
        data-lyra-lang={lang}
        lang={lang}
      >
        {lang.toUpperCase()}
      </button>
    ))
  }
</div>

<script>
  import { shellLabels, LYRA_LOCALE_STORAGE_KEY, LYRA_LOCALE_COOKIE } from "../../i18n/shell";

  const valid = new Set(["en", "es", "de"]);

  /** Cookie is set by the switcher + static pages (e.g. marea.html); must not be ignored when localStorage is empty. */
  function getCookieLocale(): string | null {
    try {
      const needle = `${LYRA_LOCALE_COOKIE}=`;
      const hit = document.cookie.split("; ").find((row) => row.startsWith(needle));
      if (!hit) return null;
      const v = decodeURIComponent(hit.slice(needle.length));
      return v && valid.has(v) ? v : null;
    } catch {
      return null;
    }
  }

  function resolveInitialLang(): string {
    const qs = new URLSearchParams(window.location.search).get("lang");
    if (qs && valid.has(qs)) return qs;
    try {
      const fromStorage = localStorage.getItem(LYRA_LOCALE_STORAGE_KEY);
      if (fromStorage && valid.has(fromStorage)) return fromStorage;
    } catch {
      /* ignore */
    }
    const fromCookie = getCookieLocale();
    if (fromCookie) return fromCookie;
    const htmlLang = document.documentElement.getAttribute("lang");
    if (htmlLang && valid.has(htmlLang)) return htmlLang;
    return "en";
  }

  function setLocaleCookie(lang: string) {
    try {
      document.cookie = `${LYRA_LOCALE_COOKIE}=${encodeURIComponent(lang)};path=/;max-age=31536000;SameSite=Lax`;
    } catch {
      /* ignore */
    }
  }

  function applyShell(lang: string) {
    const labels = shellLabels[lang as keyof typeof shellLabels] as Record<string, string> | undefined;
    if (!labels) return;
    document.querySelectorAll("[data-shell-i18n]").forEach((el) => {
      const k = el.getAttribute("data-shell-i18n");
      if (k != null && labels[k] != null) el.textContent = labels[k];
    });
  }

  function syncLangButtons(lang: string) {
    document.querySelectorAll(".lyra-lang-btn").forEach((b) => {
      b.classList.toggle("is-active", b.getAttribute("data-lyra-lang") === lang);
    });
  }

  function setLang(lang: string) {
    if (!valid.has(lang)) return;
    try {
      localStorage.setItem(LYRA_LOCALE_STORAGE_KEY, lang);
    } catch {
      /* ignore */
    }
    setLocaleCookie(lang);
    document.documentElement.lang = lang;
    applyShell(lang);
    syncLangButtons(lang);
    window.dispatchEvent(new CustomEvent("lyra-locale-changed", { detail: { lang } }));
  }

  function initLyraLocale() {
    setLang(resolveInitialLang());
  }

  window.LyraSetLang = setLang;

  /**
   * Bind each toggle directly so clicks work even when `event.target` is a text node,
   * and re-bind after View Transitions (new DOM nodes).
   */
  const wiredLangBtns = new WeakSet<Element>();
  function wireLangButtons() {
    document.querySelectorAll("[data-lyra-lang]").forEach((node) => {
      if (!(node instanceof HTMLElement)) return;
      if (wiredLangBtns.has(node)) return;
      wiredLangBtns.add(node);
      node.addEventListener("click", (e) => {
        e.preventDefault();
        const lang = node.getAttribute("data-lyra-lang");
        if (lang && valid.has(lang)) setLang(lang);
      });
    });
  }

  function onShellPage() {
    wireLangButtons();
    initLyraLocale();
  }

  const g = globalThis as typeof globalThis & { __lyraShellI18nReady?: boolean };
  if (!g.__lyraShellI18nReady) {
    g.__lyraShellI18nReady = true;
    document.addEventListener("astro:page-load", onShellPage);
    window.addEventListener("pageshow", (e) => {
      if (e.persisted) onShellPage();
    });
  }
  onShellPage();
  /* Re-run after other deferred work (e.g. Fidelis text splits) may touch the DOM. */
  requestAnimationFrame(() => {
    requestAnimationFrame(() => onShellPage());
  });
</script>
