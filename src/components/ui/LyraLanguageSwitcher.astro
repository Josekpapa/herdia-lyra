---
import { shellLabels, LYRA_LOCALE_STORAGE_KEY } from "../../i18n/shell";

const locales = ["en", "es", "de"] as const;
---

<div class="lyra-lang-switcher" aria-label="Language">
  {
    locales.map((lang) => (
      <button
        type="button"
        class="lyra-lang-btn"
        data-lyra-lang={lang}
        lang={lang}
      >
        {lang.toUpperCase()}
      </button>
    ))
  }
</div>

<script is:inline define:vars={{ shellLabels, LYRA_LOCALE_STORAGE_KEY }}>
  (function () {
    const valid = new Set(["en", "es", "de"]);
    function getLang() {
      try {
        const v = localStorage.getItem(LYRA_LOCALE_STORAGE_KEY);
        return valid.has(v) ? v : "en";
      } catch {
        return "en";
      }
    }
    function applyShell(lang) {
      const labels = shellLabels[lang];
      if (!labels) return;
      document.querySelectorAll("[data-shell-i18n]").forEach((el) => {
        const k = el.getAttribute("data-shell-i18n");
        if (k && labels[k] != null) el.textContent = labels[k];
      });
    }
    function setLang(lang) {
      if (!valid.has(lang)) return;
      try {
        localStorage.setItem(LYRA_LOCALE_STORAGE_KEY, lang);
      } catch {
        /* ignore */
      }
      document.documentElement.lang = lang;
      applyShell(lang);
      document.querySelectorAll(".lyra-lang-btn").forEach((b) => {
        b.classList.toggle("is-active", b.getAttribute("data-lyra-lang") === lang);
      });
      window.dispatchEvent(new CustomEvent("lyra-locale-changed", { detail: { lang } }));
    }
    window.LyraSetLang = setLang;
    document.querySelectorAll(".lyra-lang-btn").forEach((b) => {
      b.addEventListener("click", () => setLang(b.getAttribute("data-lyra-lang")));
    });
    const qs = new URLSearchParams(window.location.search).get("lang");
    const initial = valid.has(qs) ? qs : getLang();
    setLang(initial);
  })();
</script>
