---
import "../styles/global.css";
import LyraLanguageSwitcher from "../components/ui/LyraLanguageSwitcher.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Fidelis — Tax AI & residency tools for financial advisors",
  description = "An embeddable tax AI agent plus a residency day-tracker for financial advisors. Grounded answers, tool-verified calculations, per-client context.",
} = Astro.props;

const user = Astro.locals.user;
const org = Astro.locals.org;
const authOn = Astro.locals.authEnabled;

const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
};

const navItems: Array<{ href: string; label: string; code: string; key: string }> = [
  { href: "/marea.html", label: "Marea", code: "00", key: "marea" },
  { href: "/fidelis", label: "Fidelis", code: "01", key: "fidelis" },
  { href: "/agent", label: "Agent", code: "02", key: "agent" },
  { href: "/scenarios", label: "Scenarios", code: "03", key: "scenarios" },
  { href: "/intake", label: "Intake", code: "04", key: "intake" },
  { href: "/tracker", label: "Tracker", code: "05", key: "tracker" },
  { href: "/audit", label: "Audit", code: "06", key: "audit" },
];
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap"
    />
  </head>
  <body class="min-h-full antialiased" data-page="app">
    <header class="relative z-20">
      <div class="mx-auto flex max-w-7xl items-stretch justify-between gap-8 px-6">
        <!-- Brand -->
        <a href="/marea.html" class="group flex items-center gap-3 py-5" aria-label="Marea — home">
          <span class="relative grid h-8 w-8 place-items-center">
            <span class="absolute inset-0 rounded-[2px] border border-white/12 transition group-hover:border-white/28"></span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-white/80 group-hover:text-white">
              <path d="M2 12h20" />
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z" />
              <circle cx="12" cy="12" r="10" />
            </svg>
          </span>
          <span class="flex flex-col leading-tight">
            <span class="text-[10px] tracking-[0.3em] uppercase text-ink-400 font-mono">
              Fidelis
            </span>
            <span class="font-display text-[15px] font-light tracking-tight text-white">
              Tax intelligence
            </span>
          </span>
        </a>

        <!-- Editorial nav -->
        <nav class="hidden items-stretch gap-6 md:flex" aria-label="Primary">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={["nav-link", isActive(item.href) && "is-active"]}
            >
              <span class="mr-2 text-ink-500/70">{item.code}</span>
              <span data-shell-i18n={`nav.${item.key}`}>{item.label}</span>
            </a>
          ))}
          {user && user.role === "admin" && (
            <a
              href="/team"
              class:list={["nav-link", isActive("/team") && "is-active"]}
            >
              <span class="mr-2 text-ink-500/70">07</span>
              <span data-shell-i18n="nav.team">Team</span>
            </a>
          )}
        </nav>

        <!-- Right side: language + user / CTA -->
        <div class="flex items-center gap-3 py-3 sm:gap-4">
          <LyraLanguageSwitcher />
          {user ? (
            <div class="hidden items-center gap-3 sm:flex">
              <div class="text-right leading-tight">
                <div class="font-mono text-[9.5px] uppercase tracking-[0.25em] text-ink-500">
                  {org?.name ?? "Workspace"}
                </div>
                <div class="text-xs text-ink-200">{user.email}</div>
              </div>
              <form method="post" action="/api/auth/logout">
                <button type="submit" class="btn-link" data-shell-i18n="cta.signout">
                  Sign out
                </button>
              </form>
            </div>
          ) : authOn ? (
            <a href="/login" class="btn-primary" data-shell-i18n="cta.signin">Sign in</a>
          ) : (
            <a href="/agent" class="btn-primary" data-shell-i18n="cta.launch">Launch agent</a>
          )}
        </div>
      </div>
      <div class="hairline-x"></div>
    </header>

    <div class="lyra-unified-strip" aria-hidden="false">
      <p class="lyra-unified-strip-inner" data-shell-i18n="strip.line">
        Travel & tax in one stack — Marea, Fidelis, and tools share this session.
      </p>
    </div>

    <!-- Mobile nav strip -->
    <div class="md:hidden">
      <div class="mx-auto flex max-w-7xl gap-4 overflow-x-auto px-6 py-3">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "whitespace-nowrap font-mono text-[10.5px] tracking-[0.22em] uppercase transition",
              isActive(item.href) ? "text-white" : "text-ink-400 hover:text-white"
            ]}
          >
            <span data-shell-i18n={`nav.${item.key}`}>{item.label}</span>
          </a>
        ))}
      </div>
      <div class="hairline-x opacity-60"></div>
    </div>

    <main class="relative z-10">
      <slot />
    </main>

    <footer class="relative z-10 mt-24">
      <div class="hairline-x opacity-60"></div>
      <div class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-10 sm:flex-row sm:items-start sm:justify-between">
        <div class="max-w-xl">
          <div class="kicker mb-2" data-shell-i18n="footer.kicker">Disclosure</div>
          <p class="text-sm leading-relaxed text-ink-300" data-shell-i18n="footer.disclosure">
            Fidelis is informational. Residency rules depend on treaties, ties,
            and facts the tool doesn't know about. Consult a qualified tax
            professional before making decisions.
          </p>
        </div>
        <div class="flex flex-col gap-1 text-right">
          <span
            class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-500"
            data-shell-i18n="footer.built"
          >
            Built with Astro · Groq
          </span>
          <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-ink-500/70">
            © {new Date().getFullYear()}{" "}
            <span data-shell-i18n="footer.copy">Fidelis</span>
          </span>
        </div>
      </div>
    </footer>
  </body>
</html>
