---
/**
 * /core — index of network plumbing (identity, memory, voice, API, billing).
 */
import AtlasLayout from "../../layouts/AtlasLayout.astro";
import { CORE } from "../../data/atlas";

const entries = CORE.map((c) => ({
  ...c,
  href: c.slug === "passport" ? "/passport" : `/core/${c.slug}`,
}));
---

<AtlasLayout
  title="Core — LYRA network plumbing"
  description="Passport, Memory, Grammar, Gateway, Billing. The rails every holding shares."
  active="home"
>
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-24">
      <div class="flex items-center gap-2 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-500">
        <a href="/atlas" class="hover:text-white transition">Atlas</a>
        <span>/</span>
        <span class="text-ink-300">Core</span>
      </div>
      <div class="kicker mb-3 mt-8">Network · 00.core</div>
      <h1 class="page-title">Core <em>plumbing</em>.</h1>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-ink-200 lede">
        Five rails shared by every holding. Same tier grammar, same Passport
        identity — different verticals, one network.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-[84rem] px-6 py-16">
      <div class="grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-3">
        {entries.map((c) => (
          <a href={c.href} class="surface group block p-6 transition hover:border-white/18">
            <div class="label-xs text-white">{c.name}</div>
            <p class="mt-3 text-[13px] leading-relaxed text-ink-300 group-hover:text-ink-200">
              {c.blurb}
            </p>
            <span class="mt-4 inline-block font-mono text-[11px] text-ink-500 group-hover:text-white">
              Open →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</AtlasLayout>
