---
/**
 * /lex/docket — LEX flagship product page.
 *
 * Docket = matter-based legal ops. The matter is the product, not the hour.
 * For boutique firms (20–50 attys) and fractional GCs serving founders.
 *
 * Voice: precise · plain-language · adversarial when needed. Accent: #c8c4bc.
 */
import AtlasLayout from "../../layouts/AtlasLayout.astro";
import AgentTile from "../../components/atlas/AgentTile.astro";
import { getHolding } from "../../data/atlas";

const lex = getHolding("lex")!;
const related = lex.agents.filter((a) => a.slug !== "matter" && a.status === "live").slice(0, 5);
---

<AtlasLayout
  title="Docket — the matter is the product · LYRA"
  description="Docket is the Lex flagship. Matter-based legal ops for boutique firms and fractional GCs. Open, scope, ship, close."
  active="lex"
>
  <!-- ────────────── HERO — precise register ────────────── -->
  <section class="relative overflow-hidden border-b border-white/5">
    <div class="bg-grid absolute inset-0 opacity-50"></div>
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(900px 520px at 25% 30%, rgba(200, 196, 188, 0.09), transparent 62%), radial-gradient(700px 440px at 80% 80%, rgba(74, 110, 184, 0.11), transparent 60%);"
    ></div>

    <div class="relative mx-auto max-w-[84rem] px-6 py-24 sm:py-32">
      <div class="flex items-center gap-2 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-500">
        <a href="/atlas" class="hover:text-white transition">Atlas</a>
        <span>/</span>
        <a href="/lex" class="hover:text-white transition">Lex</a>
        <span>/</span>
        <span class="text-ink-300">Docket</span>
      </div>

      <div class="mt-8 flex items-center gap-3">
        <span class="kicker">Flagship · 07.00</span>
        <span class="tag tag-accent">● live</span>
        <span class="label-xs">PAGE · CHAPTER · VOLUME</span>
      </div>

      <h1 class="mt-8 font-display text-[clamp(3rem,10vw,8rem)] font-light leading-[0.9] tracking-tight text-white">
        Docket
      </h1>

      <p class="mt-4 max-w-2xl font-display text-2xl italic font-light text-ink-200/90">
        The matter is the product.
      </p>

      <div class="hairline mt-8 max-w-md"></div>

      <p class="mt-8 max-w-3xl text-lg leading-relaxed text-ink-200 lede">
        Most firms bill by the hour and pretend the hour is the product. The
        matter is. Docket opens it, scopes it, drafts it, calendars it, bills
        it, files it, closes it — in the house voice of your firm, on the
        rails of the LYRA network.
      </p>

      <div class="mt-12 flex flex-wrap items-center gap-3">
        <a href="/join" class="btn-primary">Request access →</a>
        <a href="#loop" class="btn-ghost">The matter loop</a>
        <a href="#pricing" class="btn-link">Pricing ↓</a>
      </div>

      <!-- Stat strip -->
      <div class="mt-16 grid grid-cols-2 gap-6 border-t border-white/5 pt-8 sm:grid-cols-4">
        <div>
          <div class="label-xs">Avg. matter cycle</div>
          <div class="mt-1 data-num text-3xl font-light text-white">−38%</div>
        </div>
        <div>
          <div class="label-xs">Clause library</div>
          <div class="mt-1 text-sm text-ink-200">your firm's, not ours</div>
        </div>
        <div>
          <div class="label-xs">Signs into</div>
          <div class="mt-1 text-sm text-ink-200">Attest · DocuSign · in person</div>
        </div>
        <div>
          <div class="label-xs">Books into</div>
          <div class="mt-1 text-sm text-ink-200">Fidelis · QuickBooks · Xero</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── THE MATTER LOOP ────────────── -->
  <section class="border-b border-white/5" id="loop">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">The matter loop</div>
      <h2 class="page-title">Open. Scope. Ship. <em>Close.</em></h2>
      <p class="mt-4 max-w-2xl text-sm text-ink-400">
        Every matter is a closed loop. Docket runs each stage, shares context
        with the rest of Lex, and hands off clean to Attest and Fidelis.
      </p>

      <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-4">
        {[
          { code: "01", title: "Open",   copy: "Conflict check · client intake · engagement letter · fee structure.", who: "Matter · Conflict" },
          { code: "02", title: "Scope",  copy: "Brief the strategy · calendar the deadlines · stage the clauses.",     who: "Brief · Clause · Calendar" },
          { code: "03", title: "Ship",   copy: "Draft · review · redline · sign · file. Your voice, not ours.",         who: "Brief · Attest" },
          { code: "04", title: "Close",  copy: "Bill the matter · book into Fidelis · archive to Vault.",               who: "Billing · Fidelis · Vault" },
        ].map((s) => (
          <div class="surface p-6">
            <div class="flex items-center justify-between">
              <span class="label-xs">{s.code}</span>
              <span class="font-mono text-[10px] text-ink-500">{s.who}</span>
            </div>
            <div class="mt-4 font-display text-2xl font-light text-white">{s.title}</div>
            <p class="mt-2 text-sm text-ink-300 leading-relaxed">{s.copy}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ────────────── TERMINAL PREVIEW ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-5 lg:items-start">
        <div class="lg:col-span-2">
          <div class="kicker mb-3">Terminal</div>
          <h2 class="section-title">An NDA in four minutes.</h2>
          <p class="mt-4 text-sm text-ink-300 leading-relaxed">
            The kind of matter that used to eat an afternoon — an NDA from a
            new counterparty — runs end-to-end inside Docket. Clause library
            reads your house voice. Attest stamps. Fidelis books the fee.
          </p>
        </div>

        <div class="lg:col-span-3">
          <div class="surface corner-ticks p-6">
            <div class="flex items-center justify-between">
              <span class="label-xs">DOCKET · M-2046 · MUTUAL NDA</span>
              <span class="tag tag-accent">● live</span>
            </div>
            <div class="mt-6 space-y-2 font-mono text-[12px] leading-relaxed">
              <div class="text-ink-500">$ lyra docket open "NDA · Vega Ventures"</div>
              <div class="text-ink-300">┌── Matter opened · M-2046 ──────────────────────</div>
              <div class="text-ink-300">│  conflict check: <span style="color:#34d399;">clear</span></div>
              <div class="text-ink-300">│  engagement: <span class="text-white">flat fee · $1,800</span> · scoped</div>
              <div class="text-ink-300">│  deadline: <span class="text-white">Thu 17:00 ET</span> · calendared</div>
              <div class="text-ink-300">└────────────────────────────────────────────────</div>
              <div class="text-ink-500 mt-4">$ lyra brief draft --mutual --house-voice</div>
              <div class="text-ink-300">  drafting · 8 clauses from your library · 0 added</div>
              <div class="text-ink-300">  → <span class="text-white">draft ready · 2 redlines needed on §4, §7</span></div>
              <div class="text-ink-500 mt-4">$ lyra docket send --counterparty vega --attest</div>
              <div class="text-ink-300">┌── Sent · awaiting signature ───────────────────</div>
              <div class="text-ink-300">│  Attest listener: armed</div>
              <div class="text-ink-300">│  Fidelis hook: will book $1,800 on close</div>
              <div class="text-ink-300">└────────────────────────────────────────────────</div>
              <div class="mt-4 flex items-center gap-2 text-ink-400">
                <span class="animate-caret">▌</span>
                <span class="text-ink-500 text-[11px]">matter active · 4 minutes elapsed</span>
              </div>
            </div>
          </div>
          <p class="mt-4 text-[11px] text-ink-500 font-mono">// static preview. live terminal lands with the first boutique firm.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── WHO IT'S FOR ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">For you if</div>
      <h2 class="page-title">You run a <em>firm</em> — or you <em>are</em> the firm.</h2>

      <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-2">
        <div class="surface p-8">
          <div class="label-xs">P3 · The Boutique GC</div>
          <div class="mt-3 font-display text-2xl font-light text-white">20–50 attorney firms</div>
          <p class="mt-3 text-sm text-ink-300 leading-relaxed">
            Practice areas that live and die on clause quality — M&A, RE, IP,
            structured finance. You already have a house voice. Docket
            operationalizes it so every attorney ships to your standard.
          </p>
          <p class="mt-6 text-sm text-ink-400">Entry · <span class="text-ink-100">Lex Desk $24k/yr</span> · 3-yr LTV <span class="text-ink-100">$200k</span></p>
        </div>
        <div class="surface p-8">
          <div class="label-xs">P7 · The Fractional GC</div>
          <div class="mt-3 font-display text-2xl font-light text-white">Solo attorneys, 8–20 clients</div>
          <p class="mt-3 text-sm text-ink-300 leading-relaxed">
            Serving founders as their outsourced general counsel. You can't be
            everywhere. Docket runs the repetitive matters so you run the ones
            that need a human. A firm in a browser tab.
          </p>
          <p class="mt-6 text-sm text-ink-400">Entry · <span class="text-ink-100">Docket solo $3k/yr</span> · 3-yr LTV <span class="text-ink-100">$30k+</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── PRICING ────────────── -->
  <section class="border-b border-white/5" id="pricing">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">Pricing · Docket</div>
      <h2 class="page-title">Three tiers. Same grammar.</h2>
      <p class="mt-4 max-w-2xl text-sm text-ink-400">{lex.model}</p>

      <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-3">
        {lex.pricing.map((p, i) => (
          <div class={`surface p-7 ${i === 1 ? "md:-translate-y-2" : ""}`} style={i === 1 ? "border-color: color-mix(in oklab, #c8c4bc 24%, rgba(255,255,255,0.06));" : undefined}>
            <div class="flex items-center justify-between">
              <span class="label-xs">{p.tier}</span>
              {i === 1 && <span class="tag">Recommended</span>}
            </div>
            <div class="mt-5 font-display text-3xl font-light text-white">{p.price}</div>
            <p class="mt-2 text-sm text-ink-300">{p.for}</p>
            <a href="/join" class={`mt-8 inline-block ${i === 1 ? "btn-primary" : "btn-ghost"}`}>Request access</a>
          </div>
        ))}
      </div>

      <p class="mt-8 max-w-2xl text-xs text-ink-500">
        Billable-hour passthrough remains yours — Docket doesn't take a piece of
        your fees. We charge for the software · you keep the matter.
      </p>
    </div>
  </section>

  <!-- ────────────── INTEGRATIONS ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">Plugs into</div>
      <h2 class="section-title">Your firm's stack, not ours.</h2>

      <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-6">
        {["Clio", "iManage", "NetDocuments", "DocuSign", "Outlook", "Google Calendar", "Westlaw", "Lexis", "QuickBooks", "Stripe", "HubSpot", "Attest"].map((n) => (
          <div class="surface p-4 text-center">
            <span class="font-mono text-[11px] tracking-[0.1em] text-ink-200">{n}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ────────────── RELATED AGENTS ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-16">
      <div class="kicker mb-3">Pairs with</div>
      <h2 class="section-title">Docket + the rest of Lex</h2>
      <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {related.map((a) => (
          <AgentTile agent={a} holdingSlug="lex" />
        ))}
      </div>
    </div>
  </section>

  <!-- ────────────── CTA ────────────── -->
  <section>
    <div class="mx-auto max-w-[84rem] px-6 py-24">
      <div class="surface-warm p-12 sm:p-20 text-center">
        <div class="kicker mb-4">Access</div>
        <h2 class="font-display text-[clamp(2rem,5vw,4rem)] font-light tracking-tight text-white">
          Bill the matter. <em class="italic-display">Ship it.</em>
        </h2>
        <p class="mt-4 max-w-xl mx-auto text-base text-ink-200 leading-relaxed">
          One boutique firm and ten fractional GCs seat in Year 1. Free Lex Desk
          for 90 days. Monthly working sessions.
        </p>
        <div class="mt-10 flex flex-wrap justify-center gap-3">
          <a href="/join" class="btn-primary">Request access</a>
          <a href="/lex" class="btn-ghost">Back to Lex</a>
        </div>
      </div>
    </div>
  </section>
</AtlasLayout>
