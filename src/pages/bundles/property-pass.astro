---
/**
 * /bundles/property-pass — build + legal + seal VOLUME bundle.
 * P4 · builder-developer · site truth + paper + books.
 */
import AtlasLayout from "../../layouts/AtlasLayout.astro";
import { getBundle } from "../../data/atlas";

const bundle = getBundle("property-pass")!;
const accent = "#8a6a26";
const accentLight = "#c3942d";

const includes = [
  { label: "Raft", href: "/mortar/raft", blurb: "The ledger for the build" },
  { label: "Attest", href: "/seal/attest", blurb: "Stamp · chain · vault in ninety seconds" },
  { label: "Matter", href: "/lex/matter", blurb: "Legal intake → Docket" },
  { label: "Ledger", href: "/fidelis/ledger", blurb: "Construction books meet advisory" },
] as const;
---

<AtlasLayout
  title="Property Pass — bundle · LYRA"
  description="VOLUME bundle: Raft + Attest + Matter + Ledger. The renovation and development spine from site to stamp to books."
  active="pricing"
>
  <section class="relative overflow-hidden border-b border-white/5">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(1000px 560px at 18% 18%, rgba(138, 106, 38, 0.14), transparent 58%), radial-gradient(720px 480px at 88% 70%, rgba(184, 146, 106, 0.08), transparent 60%);"
    ></div>
    <div class="relative mx-auto max-w-[84rem] px-6 py-24 sm:py-28">
      <div class="flex items-center gap-2 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-500">
        <a href="/atlas" class="hover:text-white transition">Atlas</a>
        <span>/</span>
        <a href="/pricing" class="hover:text-white transition">Pricing</a>
        <span>/</span>
        <span class="text-ink-300">Property Pass</span>
      </div>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <span class="kicker">Bundle · 03.property</span>
        <span class="tag tag-accent">{bundle.tier}</span>
        <span class="label-xs text-ink-400">MORTAR × SEAL × LEX × FIDELIS</span>
      </div>
      <h1 class="mt-8 font-display text-[clamp(2.75rem,8vw,5.5rem)] font-light leading-[0.92] tracking-tight text-white">
        Property Pass
      </h1>
      <p class="mt-4 max-w-2xl font-display text-2xl italic font-light text-ink-200/90">
        Site · stamp · matter · books.
      </p>
      <div class="hairline mt-8 max-w-md"></div>
      <p class="mt-8 max-w-3xl text-lg leading-relaxed text-ink-200 lede">
        Property Pass is the VOLUME anchor for P4 — the operator who lives in
        draws, RFIs, and lender asks. Raft holds the build; Attest stamps what
        crosses borders; Matter opens legal intake without a new retainer
        dance; Ledger keeps the job books honest for the family office or the
        bank.
      </p>
      <div class="mt-12 flex flex-wrap gap-3">
        <a href="/join" class="btn-primary">Request Property Pass →</a>
        <a href="/mortar/raft" class="btn-ghost">See Raft</a>
        <a href="/pricing" class="btn-link">All bundles</a>
      </div>
      <div class="mt-14 grid grid-cols-2 gap-6 border-t border-white/5 pt-8 sm:grid-cols-4">
        <div>
          <div class="label-xs">Bundle price</div>
          <div class="mt-1 data-num text-3xl font-light text-white">{bundle.price}</div>
        </div>
        <div>
          <div class="label-xs">Floor story</div>
          <div class="mt-1 text-sm text-ink-200">~$60k ARR + % of project</div>
        </div>
        <div>
          <div class="label-xs">Persona</div>
          <div class="mt-1 text-sm text-ink-200">P4 · Builder-Developer</div>
        </div>
        <div>
          <div class="label-xs">Tier grammar</div>
          <div class="mt-1 text-sm text-ink-200">VOLUME · cross-holding</div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">What's inside</div>
      <h2 class="page-title">Four agents · one project ID.</h2>
      <p class="mt-4 max-w-2xl text-sm text-ink-400">
        Raft's project code flows to Matter as matter context, to Attest as
        stamp routing, to Ledger as job costing — Property Pass is the bundle
        that keeps the IDs aligned.
      </p>
      <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {includes.map((item) => (
          <a
            href={item.href}
            class="surface group block p-6 transition hover:border-white/18"
            style={`border-color: color-mix(in oklab, ${accent} 24%, rgba(255,255,255,0.06));`}
          >
            <div class="label-xs" style={`color: ${accentLight};`}>{item.label}</div>
            <p class="mt-3 text-[14px] leading-relaxed text-ink-300 group-hover:text-ink-200">
              {item.blurb}
            </p>
            <span class="mt-4 inline-block font-mono text-[11px] text-ink-500 group-hover:text-white">Open agent →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">Before / after</div>
      <h2 class="page-title">Fewer seams between dirt and diligence.</h2>
      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="surface-warm p-8">
          <div class="label-xs text-ink-500">Before</div>
          <ul class="mt-6 space-y-3 text-sm leading-relaxed text-ink-300">
            <li class="flex gap-3"><span class="font-mono text-ink-500">—</span>Procore + email + notary's car</li>
            <li class="flex gap-3"><span class="font-mono text-ink-500">—</span>Draw package Friday · COs in WhatsApp</li>
            <li class="flex gap-3"><span class="font-mono text-ink-500">—</span>Legal engagement restarted per phase</li>
          </ul>
        </div>
        <div class="surface p-8" style={`border-color: color-mix(in oklab, ${accent} 28%, rgba(255,255,255,0.06));`}>
          <div class="label-xs" style={`color: ${accentLight};`}>After · Property Pass</div>
          <ul class="mt-6 space-y-3 text-sm leading-relaxed text-ink-200">
            <li class="flex gap-3"><span class="font-mono" style={`color:${accentLight};`}>●</span>Raft is the single ledger for site + draws</li>
            <li class="flex gap-3"><span class="font-mono" style={`color:${accentLight};`}>●</span>Attest routes stamps with project + vault hashes</li>
            <li class="flex gap-3"><span class="font-mono" style={`color:${accentLight};`}>●</span>Matter + Ledger keep legal and COA in one story</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-white/5" data-page="app">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-5 lg:items-start">
        <div class="lg:col-span-2">
          <div class="kicker mb-3">Receipt</div>
          <h2 class="section-title">Project bundle · VOLUME.</h2>
          <p class="mt-4 text-sm text-ink-400">
            Mortar portfolio fee still applies on large GMP — Passport knows the
            relationship.
          </p>
        </div>
        <div class="lg:col-span-3">
          <div class="surface corner-ticks p-8" style={`border-color: color-mix(in oklab, ${accent} 26%, rgba(255,255,255,0.06));`}>
            <div class="flex items-center justify-between">
              <span class="label-xs" style={`color: ${accentLight};`}>LYRA · BUNDLE · PROPERTY-PASS</span>
              <span class="tag tag-accent">{bundle.tier}</span>
            </div>
            <pre class="mt-6 whitespace-pre-wrap font-mono text-[12.5px] leading-relaxed text-ink-200">
LINE ITEM                          AMOUNT
──────────────────────────────────────────
BUNDLE · Property Pass (VOLUME)    {bundle.price}
  MORTAR · Raft                    included
  SEAL · Attest                    included
  LEX · Matter                     included
  FIDELIS · Ledger                 included
Passport · project + entities      included
──────────────────────────────────────────
<span class="text-ink-500">// +0.75% of project on VOLUME Mortar terms where applicable</span>
</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-[84rem] px-6 py-24">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div>
          <div class="kicker mb-3">Mortar</div>
          <h2 class="page-title">Ship the build · keep the paper honest.</h2>
          <p class="mt-4 max-w-xl text-sm text-ink-300">
            We wire your first project end-to-end: Raft project ID, Attest
            routing, Matter templates for your counsel, Ledger chart for job
            cost.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/join" class="btn-primary">Apply →</a>
          <a href="/mortar" class="btn-ghost">Back to Mortar</a>
        </div>
      </div>
    </div>
  </section>
</AtlasLayout>
