---
/**
 * /bundles — index of revenue bundles from atlas.ts
 */
import AtlasLayout from "../../layouts/AtlasLayout.astro";
import { BUNDLES } from "../../data/atlas";
---

<AtlasLayout
  title="Bundles — LYRA"
  description="Cross-holding packages — Shore Pack, Founder Pass, Lex Desk, Site Pack, and the full catalog. All inside the tier grammar."
  active="pricing"
>
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-24">
      <div class="flex items-center gap-2 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-500">
        <a href="/atlas" class="hover:text-white transition">Atlas</a>
        <span>/</span>
        <span class="text-ink-300">Bundles</span>
      </div>
      <div class="kicker mb-3 mt-8">Pricing · 96</div>
      <h1 class="page-title">Cross-holding <em>bundles</em>.</h1>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-ink-200 lede">
        Every bundle is priced inside PAGE / CHAPTER / VOLUME / ATLAS. Open a narrative
        landing below; full tier tables live on{" "}
        <a href="/pricing" class="text-white underline-offset-4 hover:underline">Pricing</a>.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-[84rem] px-6 py-16">
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        {BUNDLES.map((b) => (
          <a
            href={`/bundles/${b.slug}`}
            class="surface group block p-6 transition hover:border-white/18"
          >
            <div class="flex items-center justify-between">
              <span class="label-xs">{b.tier}</span>
              <span class="data-num text-ink-100">{b.price}</span>
            </div>
            <div class="mt-3 font-display text-xl font-light text-white">{b.name}</div>
            <p class="mt-2 text-[13px] text-ink-400">{b.includes.join(" · ")}</p>
            <span class="mt-4 inline-block font-mono text-[11px] text-ink-500 group-hover:text-white">
              Bundle page →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</AtlasLayout>
