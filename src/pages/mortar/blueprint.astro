---
/**
 * /mortar/blueprint — Mortar · Blueprint sub-agent product page.
 *
 * Blueprint = drawings that read back to you. Sheet sets, RFIs,
 * redlines, permit versions. The drawing you're looking at is
 * the drawing being built.
 *
 * Voice: direct · tactical · on-site (inherits Mortar).
 * Accent: #8faec4 (blueprint paper-blue, differentiated from Raft bronze).
 */
import AtlasLayout from "../../layouts/AtlasLayout.astro";
import AgentTile from "../../components/atlas/AgentTile.astro";
import { getHolding } from "../../data/atlas";

const mortar = getHolding("mortar")!;
const agent = mortar.agents.find((a) => a.slug === "blueprint")!;
const related = mortar.agents.filter((a) => a.slug !== "blueprint" && a.status === "live").slice(0, 5);
---

<AtlasLayout
  title="Blueprint — Mortar · LYRA"
  description="Every sheet, in one place. Sheet sets, RFIs, redlines, permit versions — the drawing you're looking at is the drawing being built. The drawings layer underneath Raft."
  active="mortar"
>
  <!-- ────────────── HERO ────────────── -->
  <section class="relative overflow-hidden border-b border-white/5">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(1100px 600px at 20% 20%, rgba(143, 174, 196, 0.13), transparent 60%), radial-gradient(760px 480px at 82% 72%, rgba(138, 106, 38, 0.07), transparent 62%);"
    ></div>

    <div class="relative mx-auto max-w-[84rem] px-6 py-24 sm:py-32">
      <div class="flex items-center gap-2 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-500">
        <a href="/atlas" class="hover:text-white transition">Atlas</a>
        <span>/</span>
        <a href="/mortar" class="hover:text-white transition">Mortar</a>
        <span>/</span>
        <span class="text-ink-300">Blueprint</span>
      </div>

      <div class="mt-8 flex items-center gap-3">
        <span class="kicker">Agent · 06.blueprint</span>
        <span class="tag tag-accent">● live</span>
        <span class="label-xs">CHAPTER · VOLUME</span>
      </div>

      <h1 class="mt-8 font-display text-[clamp(3rem,10vw,8rem)] font-light leading-[0.9] tracking-tight text-white">
        Blueprint
      </h1>

      <p class="mt-4 max-w-2xl font-display text-2xl italic font-light text-ink-200/90">
        Every sheet, in one place.
      </p>

      <div class="hairline mt-8 max-w-md"></div>

      <p class="mt-8 max-w-3xl text-lg leading-relaxed text-ink-200 lede">
        Raft is the ledger for the build. Blueprint is the drawings
        that feed it — the sheet set, the RFIs, the redlines, the
        permit versions. No more AIA_set_v12_REV_B_FINAL.pdf on a
        USB stick. The drawing you are looking at is the drawing
        being built.
      </p>

      <div class="mt-12 flex flex-wrap items-center gap-3">
        <a href="/join" class="btn-primary">Request access →</a>
        <a href="#how" class="btn-ghost">How it works</a>
        <a href="#pricing" class="btn-link">Pricing ↓</a>
      </div>

      <div class="mt-16 grid grid-cols-2 gap-6 border-t border-white/5 pt-8 sm:grid-cols-4">
        <div>
          <div class="label-xs">Versioning</div>
          <div class="mt-1 data-num text-3xl font-light text-white">sheet-set</div>
        </div>
        <div>
          <div class="label-xs">RFI turnaround</div>
          <div class="mt-1 data-num text-3xl font-light text-white">9 d → 2 d</div>
        </div>
        <div>
          <div class="label-xs">Formats</div>
          <div class="mt-1 text-sm leading-relaxed text-ink-200">CAD · PDF · Revit · photo redline</div>
        </div>
        <div>
          <div class="label-xs">Target operator</div>
          <div class="mt-1 text-sm leading-relaxed text-ink-200">P4 · Builder-Developer</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── WHY A SUB-AGENT GETS ITS OWN PAGE ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-5 md:items-start">
        <div class="md:col-span-2">
          <div class="kicker mb-3">Why Blueprint is its own product</div>
          <h2 class="section-title">The drawings are the spec. Blueprint makes them readable.</h2>
        </div>
        <div class="md:col-span-3">
          <p class="text-base leading-relaxed text-ink-200">
            Every dispute on a build traces back to a drawing. Which
            version. What changed. Who approved it. Raft tracks the
            money and the people. Blueprint tracks the document those
            dollars and people reference.
          </p>
          <p class="mt-6 text-base leading-relaxed text-ink-300">
            Architects buy Blueprint standalone — one project, one
            sheet set — before the rest of Raft is even needed. GCs
            take Site Pack. Developers take the portfolio tier.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── BEFORE / AFTER ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">What Blueprint replaces</div>
      <h2 class="page-title">Twelve PDFs, three emails, one disputed change-order.</h2>
      <p class="mt-4 max-w-2xl text-sm text-ink-400">
        The sheet set in the permit office is not the sheet set on
        the GC's iPad is not the sheet set the owner signed. Blueprint
        collapses all three into the same source of truth.
      </p>

      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="surface-warm p-8">
          <div class="label-xs text-ink-500">Before · where the drawings live</div>
          <ul class="mt-6 space-y-3 text-sm leading-relaxed text-ink-300">
            <li class="flex gap-3"><span class="font-mono text-ink-500">—</span>Dropbox with 14 versions named v7 · v7b · v7b-FINAL</li>
            <li class="flex gap-3"><span class="font-mono text-ink-500">—</span>RFIs tracked in a Gmail thread with 23 replies</li>
            <li class="flex gap-3"><span class="font-mono text-ink-500">—</span>Permit set on a USB stick the expediter hand-carried</li>
            <li class="flex gap-3"><span class="font-mono text-ink-500">—</span>Redlines photographed on a phone, emailed Friday, lost Monday</li>
            <li class="flex gap-3"><span class="font-mono text-ink-500">—</span>Change-order written against a sheet nobody can locate</li>
          </ul>
        </div>
        <div class="surface p-8" style="border-color: color-mix(in oklab, #8faec4 32%, rgba(255,255,255,0.06));">
          <div class="label-xs text-white">After · Blueprint</div>
          <ul class="mt-6 space-y-3 text-sm leading-relaxed text-ink-200">
            <li class="flex gap-3"><span class="font-mono" style="color:#8faec4;">●</span>One current sheet set · every revision archived with diff</li>
            <li class="flex gap-3"><span class="font-mono" style="color:#8faec4;">●</span>RFI tied to a sheet, a region, a date, a responder</li>
            <li class="flex gap-3"><span class="font-mono" style="color:#8faec4;">●</span>Permit version branched and tracked against current set</li>
            <li class="flex gap-3"><span class="font-mono" style="color:#8faec4;">●</span>Photo redlines OCR'd, placed on the sheet, routed to architect</li>
            <li class="flex gap-3"><span class="font-mono" style="color:#8faec4;">●</span>Change-orders reference a specific sheet revision · no ambiguity</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── HOW IT WORKS ────────────── -->
  <section id="how" class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">How it works</div>
      <h2 class="page-title">Ingest · Version · Query · Tie.</h2>

      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        <div class="surface p-6">
          <div class="label-xs text-white">01 · Ingest</div>
          <p class="mt-3 text-[14px] leading-relaxed text-ink-200">
            CAD (DWG, DXF), Revit IFC, PDF sheet sets, photographed
            redlines from the field. Parsed, indexed, thumbnailed.
            Every sheet named the way your firm names them.
          </p>
        </div>
        <div class="surface p-6">
          <div class="label-xs text-white">02 · Version</div>
          <p class="mt-3 text-[14px] leading-relaxed text-ink-200">
            Every revision stored with a visual diff against the
            prior sheet. Branches for permit set, owner review,
            issued-for-construction. No version is ever lost.
          </p>
        </div>
        <div class="surface p-6">
          <div class="label-xs text-white">03 · Query</div>
          <p class="mt-3 text-[14px] leading-relaxed text-ink-200">
            Plain question, plain answer. "Show me where sheet A-102
            changed in the last 30 days." "What RFIs are open on
            mechanical?" Ties back to the drawing that was asked.
          </p>
        </div>
        <div class="surface p-6">
          <div class="label-xs text-white">04 · Tie</div>
          <p class="mt-3 text-[14px] leading-relaxed text-ink-200">
            To Permit · Site · Crew · Ledger-C. A change-order
            references a specific sheet revision. A draw references
            the issued-for-construction set. No more disputes about
            which drawing was built to.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── TERMINAL ────────────── -->
  <section class="border-b border-white/5" data-page="app">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-5 lg:items-start">
        <div class="lg:col-span-2">
          <div class="kicker mb-3">Terminal</div>
          <h2 class="section-title">Day 127, three open RFIs.</h2>
          <p class="mt-4 text-sm text-ink-400">
            34-key boutique hotel renovation. The architect, the GC,
            the owner, and the city are all reading the same set.
          </p>
        </div>
        <div class="lg:col-span-3">
          <div class="surface corner-ticks p-8"
               style="border-color: color-mix(in oklab, #8faec4 32%, rgba(255,255,255,0.06));">
            <div class="flex items-center justify-between">
              <span class="label-xs text-white">BLUEPRINT · PROJECT P-0042 · DAY 127</span>
              <span class="tag tag-accent">● live</span>
            </div>
            <pre class="mt-6 whitespace-pre-wrap font-mono text-[12.5px] leading-relaxed text-ink-200">
$ lyra blueprint brief

┌─ Project P-0042 · Boutique hotel reno ──────
│ Sheets ........ 142  · current set v6.2
│ Permit set .... v4.1  (filed Feb 03)
│ Open RFIs ..... 3  · avg age 1.6 d
│ Change orders . 2 pending · 1 approved
│ Last update ... 07:22 · A-201 redline
└──────────────────────────────────────────────

$ lyra blueprint rfi --open

  RFI-041 · mechanical · sheet M-302
    ▸ "Ceiling height @ corridor 2 conflicts
       with duct run — confirm clearance."
    → routed to architect · age 2.1 d

  RFI-042 · structural · sheet S-104
    ▸ "Beam callout mismatch between
       S-104 and permit v4.1."
    → routed to SE · age 1.4 d

  RFI-043 · electrical · sheet E-201
    ▸ "Panel schedule references E-202
       which doesn't exist in v6.2."
    → routed to MEP · age 0.3 d

$ lyra blueprint diff A-201 --last 30d

  Sheet A-201 · revision history
    v6.2 · 04/19 · <span style="color:#8faec4;">●</span> field redline · millwork layout
    v6.1 · 04/11 · change-order CO-002 · applied
    v6.0 · 04/03 · permit sync · no deltas
    v5.4 · 03/22 · issued-for-construction

$ lyra blueprint tie CO-002

  → References sheet A-201 v6.0 (pre-CO)
  → Draw #4 released against v6.1 (post-CO)
  → Ledger-C entry · $14,220 · verified

  <span class="text-ink-500">// static preview. live blueprint lands with the first project.</span>
</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── USE CASE ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-5 md:items-start">
        <div class="md:col-span-2">
          <div class="kicker mb-3">Use case</div>
          <h2 class="section-title">A 34-key hotel reno, four stakeholders.</h2>
          <p class="mt-4 text-sm text-ink-400">Anonymized. P4 profile. Blueprint bundled with Site Pack.</p>
        </div>
        <div class="md:col-span-3 space-y-6">
          <div class="surface p-6">
            <div class="label-xs">00 · The setup</div>
            <p class="mt-3 text-[14px] leading-relaxed text-ink-200">
              Boutique hotel reno, 34 keys, $8.2M GMP. Architect
              out-of-state, GC on site, owner-operator traveling,
              city permit office local. Four versions of the same
              sheet set in circulation week one.
            </p>
          </div>
          <div class="surface p-6">
            <div class="label-xs">01 · Week four</div>
            <p class="mt-3 text-[14px] leading-relaxed text-ink-200">
              Blueprint ingests the permit set, the architect's
              current DWG, and the GC's markups. Single source of
              truth published. RFI turnaround drops from 9 days
              average to 2. Field redlines reach the architect same-day.
            </p>
          </div>
          <div class="surface p-6" style="border-color: color-mix(in oklab, #8faec4 28%, rgba(255,255,255,0.06));">
            <div class="label-xs text-white">02 · Close-out</div>
            <p class="mt-3 text-[14px] leading-relaxed text-ink-200">
              Change-order disputes: one in 127 days (prior project
              average: eleven). Every CO references a specific sheet
              revision. Every draw references the set it was built
              against. As-built package delivered same week as final
              punch list · not six months later.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── PRICING ────────────── -->
  <section id="pricing" class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">Pricing · Blueprint</div>
      <h2 class="page-title">One project, Site Pack, or portfolio.</h2>
      <p class="mt-4 max-w-xl text-sm text-ink-400">
        Architects and solo GCs run Blueprint standalone at PAGE.
        Builders running full projects take Site Pack. Developers
        with 3+ active jobs take the portfolio tier.
      </p>

      <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-3">
        <div class="surface p-8">
          <div class="flex items-start justify-between">
            <div class="label-xs">PAGE · Blueprint solo</div>
          </div>
          <div class="mt-6 font-display text-4xl font-light text-white data-num">$249 / mo</div>
          <p class="mt-3 text-[13px] leading-relaxed text-ink-300">
            One project · one sheet set · unlimited RFIs
          </p>
          <a href="/join" class="btn-ghost mt-8 inline-block">Request access</a>
        </div>
        <div class="surface p-8 md:-translate-y-2"
             style="border-color: color-mix(in oklab, #8faec4 38%, rgba(255,255,255,0.06));">
          <div class="flex items-start justify-between">
            <div class="label-xs">CHAPTER · Site Pack</div>
            <span class="tag tag-accent">Recommended</span>
          </div>
          <div class="mt-6 font-display text-4xl font-light text-white data-num">$1,499 / mo</div>
          <p class="mt-3 text-[13px] leading-relaxed text-ink-300">
            Blueprint + Permit + Site + Crew · one active project
          </p>
          <a href="/join" class="btn-primary mt-8 inline-block">Request access</a>
        </div>
        <div class="surface p-8">
          <div class="flex items-start justify-between">
            <div class="label-xs">VOLUME · Portfolio</div>
          </div>
          <div class="mt-6 font-display text-4xl font-light text-white data-num">$7,990 / mo</div>
          <p class="mt-3 text-[13px] leading-relaxed text-ink-300">
            3+ active projects · +0.75% of project value · shared library
          </p>
          <a href="/join" class="btn-ghost mt-8 inline-block">Request access</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── INTEGRATIONS ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-16">
      <div class="kicker mb-3">Integrations</div>
      <h2 class="section-title">Reads the drawing. Writes the revision.</h2>

      <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        {[
          "AutoCAD (DWG/DXF)", "Revit (IFC)", "Bluebeam", "PlanGrid", "Procore (import)",
          "Buildertrend (import)", "Dropbox", "Google Drive", "Raft (native)",
          "Permit (native)", "Ledger-C (native)", "Attest"
        ].map((n) => (
          <div class="surface px-4 py-3 text-center">
            <div class="font-mono text-[11px] tracking-wider text-ink-300">{n}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ────────────── RELATED AGENTS IN MORTAR ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-16">
      <div class="kicker mb-3">More inside Mortar</div>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-5">
        {related.map((a) => (
          <AgentTile agent={a} holdingSlug="mortar" />
        ))}
      </div>
    </div>
  </section>

  <!-- ────────────── CTA ────────────── -->
  <section>
    <div class="mx-auto max-w-[84rem] px-6 py-24">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div>
          <div class="kicker mb-3">Design partner cohort</div>
          <h2 class="page-title">Blueprint opens with two projects.</h2>
          <p class="mt-4 max-w-xl text-sm text-ink-300">
            We ingest the current sheet set and three months of RFIs
            in the first week. Design partners lock CHAPTER pricing
            through close-out · no matter how long the build runs.
          </p>
        </div>
        <div class="flex gap-3">
          <a href="/join" class="btn-primary">Apply →</a>
          <a href="/mortar/raft" class="btn-ghost">See Raft</a>
          <a href="/mortar" class="btn-link">Back to Mortar →</a>
        </div>
      </div>
    </div>
  </section>
</AtlasLayout>
