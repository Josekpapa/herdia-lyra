---
/**
 * Dynamic agent + flagship route.
 *
 * Matches every /{holding}/{agent} URL. Looks up the data in atlas.ts. If the
 * agent is the holding's flagship AND has an externalHtml (like /marea.html),
 * we redirect there. Otherwise we render a product-page stub that's ready to
 * be fleshed out one-by-one (hero · demo · pricing · integrations · CTA).
 *
 * Static /tide, /lex, etc. (index.astro files) take priority over this —
 * Astro's router only falls through to dynamic routes when no static match.
 */
import AtlasLayout from "../../layouts/AtlasLayout.astro";
import { getHolding } from "../../data/atlas";

const { holding: holdingSlug, agent: agentSlug } = Astro.params;

const holding = getHolding(String(holdingSlug ?? ""));
if (!holding) {
  return new Response("Not found", { status: 404 });
}

// Flagship? (e.g. /tide/marea, /lex/docket, /helios/crest)
const isFlagship = holding.flagship?.slug === agentSlug;

// If flagship has an external HTML demo (Tide → /marea.html), redirect there.
if (isFlagship && holding.flagship?.externalHtml) {
  return Astro.redirect(holding.flagship.externalHtml, 307);
}

// Otherwise, find the agent in the agents array.
const agent = holding.agents.find((a) => a.slug === agentSlug);

if (!agent && !isFlagship) {
  return new Response("Not found", { status: 404 });
}

// Derived display data
const displayName = isFlagship ? holding.flagship!.name : agent!.name;
const displayBlurb = isFlagship ? holding.flagship!.blurb : agent!.blurb;
const displayStatus = isFlagship ? "live" : agent!.status;
const displayTier   = isFlagship ? "VOLUME" : agent!.tier;
const kind = isFlagship ? "Flagship" : "Agent";

// Surface adjacent agents in this holding for a "while you're here" row
const siblings = holding.agents.filter((a) => a.slug !== agentSlug).slice(0, 6);
---

<AtlasLayout
  title={`${displayName} — ${holding.name} · LYRA`}
  description={displayBlurb}
  active={holding.slug}
>
  <!-- ────────────── PRODUCT HERO ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <!-- breadcrumb -->
      <div class="flex items-center gap-2 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-500">
        <a href="/atlas" class="hover:text-white transition">Atlas</a>
        <span>/</span>
        <a href={`/${holding.slug}`} class="hover:text-white transition">{holding.name}</a>
        <span>/</span>
        <span class="text-ink-300">{displayName}</span>
      </div>

      <div class="mt-8 flex items-start justify-between gap-10">
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-3">
            <span class="kicker">{kind} · {holding.code}.{isFlagship ? "00" : agent!.slug}</span>
            <span class={displayStatus === "live" ? "tag tag-accent" : "tag"}>
              {displayStatus === "live" ? "● live" : "○ drafting"}
            </span>
            <span class="label-xs">{displayTier}</span>
          </div>

          <h1 class="mt-6 font-display text-[clamp(3rem,7vw,5.5rem)] font-light leading-[0.95] tracking-tight text-white">
            {displayName}
          </h1>

          <p class="mt-4 max-w-2xl font-display text-xl italic font-light text-ink-200/90">
            {displayBlurb}
          </p>

          <div class="hairline mt-8 max-w-md"></div>

          <p class="mt-8 max-w-2xl text-base leading-relaxed text-ink-300">
            {displayName} is part of {holding.name}, the LYRA {holding.vertical}
            operating layer. It runs on the same Passport, Memory, Grammar,
            Gateway, and Billing rails as every other agent in the network.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-3">
            {displayStatus === "live" ? (
              <a href="/join" class="btn-primary">Request access →</a>
            ) : (
              <span class="btn-ghost" aria-disabled="true">In development</span>
            )}
            <a href={`/${holding.slug}`} class="btn-ghost">Back to {holding.name}</a>
            <a href="/pricing" class="btn-link">Pricing →</a>
          </div>
        </div>

        <!-- Terminal preview placeholder — fleshed out per-agent later -->
        <aside class="hidden lg:block w-[26rem] shrink-0">
          <div class="surface corner-ticks p-6 aspect-[4/5]">
            <div class="flex items-center justify-between">
              <span class="label-xs">Preview</span>
              <span class="tag">{holding.name}</span>
            </div>
            <div class="mt-6 space-y-3 font-mono text-[11.5px] leading-relaxed text-ink-300">
              <div><span class="text-ink-500">$</span> lyra open {holding.slug}/{agentSlug}</div>
              <div class="text-ink-400">┌─ {displayName.toUpperCase()} ──────────────┐</div>
              <div class="text-ink-400">│  status: <span class="text-accent-400">{displayStatus}</span></div>
              <div class="text-ink-400">│  tier:   {displayTier}</div>
              <div class="text-ink-400">│  voice:  {holding.voice.tone.split(" · ")[0]}</div>
              <div class="text-ink-400">└──────────────────────────────┘</div>
              <div class="mt-6 text-ink-500">// live terminal preview lands</div>
              <div class="text-ink-500">// when this agent is developed</div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ────────────── STRUCTURE · MODEL · PRICING · DEMO · PITCH · SELL ────────────── -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-16">
      <div class="kicker mb-3">The six questions</div>
      <h2 class="section-title">Structure · Model · Pricing · Demo · Pitch · Sell</h2>
      <p class="mt-2 max-w-2xl text-sm text-ink-400">
        Every agent answers these six. This stub inherits the holding's answers
        until the agent is developed in full.
      </p>

      <div class="mt-10 grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-3">
        <div class="surface p-5">
          <div class="label-xs">Structure</div>
          <p class="mt-3 text-[13px] text-ink-300 leading-relaxed">
            Lives inside {holding.name}. Shares data with every agent in
            {holding.name} and — via Memory — the rest of the network.
          </p>
        </div>
        <div class="surface p-5">
          <div class="label-xs">Model</div>
          <p class="mt-3 text-[13px] text-ink-300 leading-relaxed">{holding.model}</p>
        </div>
        <div class="surface p-5">
          <div class="label-xs">Pricing</div>
          <p class="mt-3 text-[13px] text-ink-300 leading-relaxed">
            Unlocks at the <span class="text-white">{displayTier}</span> tier of {holding.name}.
          </p>
          <a href="/pricing" class="mt-3 inline-block btn-link">See tiers →</a>
        </div>
        <div class="surface p-5">
          <div class="label-xs">Demo</div>
          <p class="mt-3 text-[13px] text-ink-300 leading-relaxed">
            {isFlagship && holding.flagship?.externalHtml
              ? "Cinematic demo lives at the flagship URL."
              : "Live interactive demo coming in this agent's development week."}
          </p>
        </div>
        <div class="surface p-5">
          <div class="label-xs">Pitch</div>
          <p class="mt-3 text-[13px] text-ink-300 leading-relaxed">{holding.thesis}</p>
        </div>
        <div class="surface p-5">
          <div class="label-xs">Sell</div>
          <p class="mt-3 text-[13px] text-ink-300 leading-relaxed">{holding.sell}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ────────────── SIBLINGS IN HOLDING ────────────── -->
  <section>
    <div class="mx-auto max-w-[84rem] px-6 py-16">
      <div class="kicker mb-3">More inside {holding.name}</div>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {siblings.map((s) => (
          <a href={`/${holding.slug}/${s.slug}`} class="surface group p-5 transition hover:border-white/20">
            <div class="flex items-center justify-between">
              <span class={s.status === "live" ? "tag tag-accent" : "tag"}>
                {s.status === "live" ? "● live" : "○ draft"}
              </span>
              <span class="label-xs">{s.tier}</span>
            </div>
            <div class="mt-3 font-display text-xl font-light text-white">{s.name}</div>
            <p class="mt-2 text-[13px] text-ink-300">{s.blurb}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</AtlasLayout>
