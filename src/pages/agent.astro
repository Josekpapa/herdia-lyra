---
import Layout from "../layouts/Layout.astro";
import AdvisorAgent from "../components/agent/AdvisorAgent.tsx";

const hasKey = !!(import.meta.env.OPENAI_API_KEY || import.meta.env.GROQ_API_KEY);
---

<Layout title="Fidelis — Agent workspace">
  <section class="mx-auto max-w-7xl px-6 pt-10 pb-6">
    <div class="mini-reveal flex flex-col gap-5">
      <span class="kicker">01 · Agent workspace</span>
      <h1 class="page-title max-w-3xl">
        A tax agent that <em>shows its work.</em>
      </h1>
      <p class="lede">
        Every number is tool-computed. Every rule is cited. Client context
        persists across conversations — drop Fidelis into any planning
        workflow and extend its tool registry as you grow.
      </p>
    </div>

    {!hasKey && (
      <div class="mini-reveal mini-reveal-d1 mt-8 flex max-w-2xl flex-col gap-2 border-l-2 border-warn-500/60 pl-4">
        <span class="label-xs text-warn-400">Provider key missing</span>
        <p class="text-sm text-ink-200">
          Set <code class="tag">GROQ_API_KEY</code> (recommended) or
          <code class="tag">OPENAI_API_KEY</code> in your environment and
          restart. The workspace still loads — message sends will return a
          clear error until a key is present.
        </p>
      </div>
    )}
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-24">
    <div class="mini-reveal mini-reveal-d2">
      <AdvisorAgent client:only="react" />
    </div>
  </section>
</Layout>
