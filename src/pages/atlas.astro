---
/**
 * /atlas — the full catalog. App-store view of every agent across every holding.
 * Grouped by holding. Filterable later (status / tier / vertical).
 */
import AtlasLayout from "../layouts/AtlasLayout.astro";
import AgentTile from "../components/atlas/AgentTile.astro";
import { HOLDINGS, totalLiveAgents, totalDraftAgents } from "../data/atlas";

const live = totalLiveAgents();
const draft = totalDraftAgents();
---

<AtlasLayout
  title="Atlas — the LYRA catalog"
  description="Every agent in the LYRA network, grouped by holding."
  active="atlas"
>
  <!-- Hero -->
  <section class="border-b border-white/5">
    <div class="mx-auto max-w-[84rem] px-6 py-20">
      <div class="kicker mb-3">Atlas · Catalog</div>
      <h1 class="page-title">Every agent. Every <em>holding</em>.</h1>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-ink-200 lede">
        The app store for LYRA. {live} live agents across {HOLDINGS.length} holdings.
        Tap any tile to open the agent's page, price, and demo.
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <span class="tag tag-accent">● {live} live</span>
        <span class="tag">○ {draft} drafting</span>
        <span class="tag">{HOLDINGS.length} holdings</span>
      </div>
    </div>
  </section>

  <!-- Sections — one per holding -->
  {HOLDINGS.map((h) => (
    <section class="border-b border-white/5" id={h.slug}>
      <div class="mx-auto max-w-[84rem] px-6 py-16">
        <div class="flex items-end justify-between gap-6">
          <div>
            <div class="flex items-center gap-3">
              <span class="kicker">{h.code}</span>
              <span class="label-xs">{h.vertical}</span>
            </div>
            <h2 class="mt-3 font-display text-3xl font-light tracking-tight text-white">
              {h.name}{h.flagship && <span class="text-ink-400"> · {h.flagship.name}</span>}
            </h2>
            <p class="mt-2 max-w-2xl text-sm text-ink-300">{h.thesis}</p>
          </div>
          <a href={`/${h.slug}`} class="btn-link whitespace-nowrap">Open {h.name} →</a>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {h.agents.map((a) => (
            <AgentTile agent={a} holdingSlug={h.slug} />
          ))}
        </div>
      </div>
    </section>
  ))}
</AtlasLayout>
