# -----------------------------------------------------------------------------
# Fidelis · environment variables
# -----------------------------------------------------------------------------
# Copy to `.env` for local dev. For Vercel, set these in the project's
# "Environment Variables" settings.
#
# Provider preference: if GROQ_API_KEY is set, Groq is used. Otherwise Fidelis
# falls back to OpenAI. Set exactly one.
# -----------------------------------------------------------------------------

# --- Groq (preferred) --------------------------------------------------------
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk-replace-me

# --- OpenAI (fallback) -------------------------------------------------------
# Only needed if you don't set GROQ_API_KEY above. OpenAI is also the only
# provider that gives true semantic RAG (embeddings) — Groq has no embeddings
# endpoint, so the knowledge base falls back to keyword search automatically.
# OPENAI_API_KEY=sk-replace-me

# --- Optional overrides ------------------------------------------------------
# Chat / tool-calling model. Defaults:
#   Groq   → llama-3.3-70b-versatile
#   OpenAI → gpt-4o-mini
# LLM_MODEL=llama-3.3-70b-versatile

# Vision model for /intake document extraction. Defaults:
#   Groq   → meta-llama/llama-4-scout-17b-16e-instruct
#   OpenAI → gpt-4o-mini
# LLM_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- LYRA Hub · service catalog & deploy signal ------------------------------
# Marketplace listing ids (per GA SKU). Key fidelis/ledger → LYRA_MP_FIDELIS_LEDGER
# LYRA_MP_FIDELIS_LEDGER=
# LYRA_MP_FIDELIS_VAULT=
# LYRA_MP_TIDE_OPS=
# LYRA_MP_TIDE_CONCIERGE=
# LYRA_MP_SEAL_STAMP=
# LYRA_MP_SEAL_CHAIN=
# LYRA_MP_TIDE_REVENUE=
# LYRA_MP_TIDE_HOUSEKEEPING=
# LYRA_MP_TIDE_GUESTBOOK=
# LYRA_MP_TIDE_SCOUT=
# LYRA_MP_LORE_TUTOR=
# LYRA_MP_LORE_PATH=
# LYRA_MP_LORE_LAB=
#
# Deploy metadata for /api/hub/surface (optional JSON object keyed by holding/agent)
# LYRA_DEPLOY_MANIFEST_JSON={"fidelis/ledger":{"lastDeploy":"2026-04-22T12:00:00.000Z","revision":"abc123"}}
# Global fallback when per-key manifest is empty:
# LYRA_LAST_DEPLOY_AT=2026-04-22T12:00:00.000Z
# LYRA_DEPLOY_REVISION=abc123

# --- LYRA Hub (optional future — do not set until you wire CRM) --------------
# PUBLIC_HUB_CRM_URL=https://example.com

# --- Auth (opt-in) -----------------------------------------------------------
# Set to 1 to enforce login on /agent, /intake, /audit, /scenarios, /memo,
# and the /api/chat, /api/compute, /api/intake routes. Leave unset (or 0)
# for open dev / demo mode. When enabled, visit /signup to create the first
# firm + admin user. Uses a local SQLite file under ./data/fidelis.sqlite —
# so do NOT enable this on Vercel (filesystem is ephemeral there).
FIDELIS_AUTH=0
